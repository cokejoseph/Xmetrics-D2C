# ─── Sentinal — Environment Variables ────────────────────────────────────────
#
# Copy this file to .env.local and fill in your actual values.
# Without these variables, the app runs in DEMO MODE (read-only seed data).
#
# To get these values:
#   1. Go to https://supabase.com and create a new project
#   2. Navigate to Project Settings → API
#   3. Copy the "Project URL" and "anon / public" key below
# ─────────────────────────────────────────────────────────────────────────────

# Required for live mode (Supabase project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Required for live mode (anon/public key — safe to expose in the browser)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Optional: API Integrations ───────────────────────────────────────────────

# Shopify (filled from Settings → Integrations inside the app, not needed here)
# VITE_SHOPIFY_API_KEY=
# VITE_SHOPIFY_STORE_DOMAIN=

# Razorpay webhook secret (used by the Supabase edge function — set in Supabase secrets, not here)
# RAZORPAY_WEBHOOK_SECRET=

# WhatsApp Business API (filled from Settings → Integrations inside the app)
# VITE_WHATSAPP_API_TOKEN=
# VITE_WHATSAPP_PHONE_NUMBER_ID=

# Shiprocket (filled from Settings → Integrations inside the app)
# VITE_SHIPROCKET_EMAIL=
# VITE_SHIPROCKET_PASSWORD=
